# Local/demo defaults
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
REPORT_JOB_STORE_DRIVER=filesystem
PDF_BROWSER_DRIVER=local

# Hosted MVP (Vercel + Xano)
# Override these values in the hosted environment:
# APP_URL=https://your-vercel-app.vercel.app
# REPORT_JOB_STORE_DRIVER=xano
# PDF_BROWSER_DRIVER=vercel
# Keep API keys server-side and never commit real values.
XANO_BASE_URL=
XANO_REPORT_JOBS_ENDPOINT=
XANO_API_KEY=

# Temporary legacy fallback if already configured:
XANO_REPORTS_ENDPOINT=

# Hosted PDF generation uses puppeteer-core with packaged Sparticuz Chromium.
# In Preview, APP_URL can be omitted so the request origin targets that deployment.
# Vercel sets VERCEL_AUTOMATION_BYPASS_SECRET automatically when Protection
# Bypass for Automation is enabled for the project.
