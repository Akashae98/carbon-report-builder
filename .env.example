# Local/demo defaults. Use a separate development Xano key and dataset if
# REPORT_JOB_STORE_DRIVER is changed to xano locally.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
REPORT_JOB_STORE_DRIVER=filesystem
PDF_BROWSER_DRIVER=local

# Production (Vercel + Xano)
# Override these values in the hosted environment:
# APP_URL=https://your-vercel-app.vercel.app
# REPORT_JOB_STORE_DRIVER=xano
# PDF_BROWSER_DRIVER=vercel

# Required only when REPORT_JOB_STORE_DRIVER=xano:
XANO_REPORT_JOBS_ENDPOINT=

# Optional API-key hardening. Leave unset until every Xano report_jobs endpoint
# validates the same private value. Keep it server-side, use separate keys per
# environment, and never add a NEXT_PUBLIC_ prefix.
# XANO_API_KEY=

# Optional project reference and temporary legacy endpoint fallback:
# XANO_BASE_URL=
# XANO_REPORTS_ENDPOINT=

# Hosted PDF generation uses puppeteer-core with packaged Sparticuz Chromium.
# In Preview, APP_URL can be omitted so the request origin targets that deployment.
# Vercel sets VERCEL_AUTOMATION_BYPASS_SECRET automatically when Protection
# Bypass for Automation is enabled for the project.
